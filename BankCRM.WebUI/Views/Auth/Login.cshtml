@using BankCRM.Dto.AuthDtos
@model LoginDto

@{
    Layout = null;
    ViewData["Title"] = "Personel Girişi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>BankCRM | Personel Girişi</title>

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --navy-950: #071426;
                --navy-900: #0b1f3a;
                --navy-800: #12345a;
                --navy-700: #1b4a78;
                --red-600: #c5152f;
                --red-700: #aa1027;
                --gray-50: #f8fafc;
                --gray-100: #f1f5f9;
                --gray-200: #e2e8f0;
                --gray-400: #94a3b8;
                --gray-500: #64748b;
                --gray-700: #334155;
                --gray-900: #0f172a;
                --white: #ffffff;
            }

            body {
                min-height: 100vh;
                font-family: Inter, "Segoe UI", Arial, sans-serif;
                background-color: var(--gray-50);
                color: var(--gray-900);
            }

            .login-page {
                min-height: 100vh;
                display: grid;
                grid-template-columns: minmax(420px, 1.08fr) minmax(480px, 0.92fr);
            }

            /* Sol bölüm */

            .login-showcase {
                position: relative;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 48px 56px;
                color: var(--white);
                background:
                    radial-gradient(circle at 20% 20%, rgba(197, 21, 47, 0.24), transparent 30%),
                    radial-gradient(circle at 82% 78%, rgba(63, 121, 181, 0.25), transparent 33%),
                    linear-gradient(145deg, var(--navy-950), var(--navy-900) 52%, #102f50);
            }

            .login-showcase::before {
                content: "";
                position: absolute;
                inset: 0;
                opacity: 0.08;
                background-image:
                    linear-gradient(rgba(255, 255, 255, 0.45) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255, 255, 255, 0.45) 1px, transparent 1px);
                background-size: 48px 48px;
            }

            .login-showcase::after {
                content: "";
                position: absolute;
                width: 430px;
                height: 430px;
                right: -170px;
                top: -150px;
                border: 1px solid rgba(255, 255, 255, 0.12);
                border-radius: 50%;
                box-shadow:
                    0 0 0 55px rgba(255, 255, 255, 0.03),
                    0 0 0 110px rgba(255, 255, 255, 0.025);
            }

            .showcase-header,
            .showcase-content,
            .showcase-footer {
                position: relative;
                z-index: 2;
            }

            .brand {
                display: inline-flex;
                align-items: center;
                gap: 13px;
            }

            .brand-symbol {
                width: 45px;
                height: 45px;
                display: grid;
                place-items: center;
                border-radius: 13px;
                background-color: var(--red-600);
                box-shadow: 0 12px 30px rgba(197, 21, 47, 0.3);
            }

            .brand-symbol svg {
                width: 25px;
                height: 25px;
            }

            .brand-name {
                font-size: 23px;
                font-weight: 750;
                letter-spacing: -0.5px;
            }

            .brand-description {
                margin-top: 2px;
                color: rgba(255, 255, 255, 0.58);
                font-size: 12px;
                letter-spacing: 0.7px;
                text-transform: uppercase;
            }

            .showcase-content {
                max-width: 610px;
                margin: 80px 0;
            }

            .showcase-badge {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 22px;
                padding: 8px 13px;
                border: 1px solid rgba(255, 255, 255, 0.14);
                border-radius: 100px;
                background-color: rgba(255, 255, 255, 0.07);
                color: rgba(255, 255, 255, 0.86);
                font-size: 12px;
                font-weight: 600;
                backdrop-filter: blur(8px);
            }

            .badge-dot {
                width: 7px;
                height: 7px;
                border-radius: 50%;
                background-color: #4ade80;
                box-shadow: 0 0 0 5px rgba(74, 222, 128, 0.12);
            }

            .showcase-title {
                max-width: 570px;
                font-size: clamp(38px, 4vw, 58px);
                line-height: 1.08;
                letter-spacing: -2px;
                font-weight: 760;
            }

            .showcase-title span {
                color: #ff536b;
            }

            .showcase-text {
                max-width: 540px;
                margin-top: 22px;
                color: rgba(255, 255, 255, 0.68);
                font-size: 16px;
                line-height: 1.8;
            }

            .feature-list {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 13px;
                margin-top: 34px;
            }

            .feature-card {
                padding: 17px 15px;
                border: 1px solid rgba(255, 255, 255, 0.11);
                border-radius: 15px;
                background-color: rgba(255, 255, 255, 0.055);
                backdrop-filter: blur(8px);
            }

            .feature-icon {
                width: 34px;
                height: 34px;
                display: grid;
                place-items: center;
                margin-bottom: 11px;
                border-radius: 9px;
                background-color: rgba(255, 255, 255, 0.09);
                color: #ffffff;
            }

            .feature-icon svg {
                width: 18px;
                height: 18px;
            }

            .feature-title {
                display: block;
                margin-bottom: 4px;
                font-size: 13px;
                font-weight: 650;
            }

            .feature-description {
                color: rgba(255, 255, 255, 0.52);
                font-size: 11px;
                line-height: 1.5;
            }

            .showcase-footer {
                color: rgba(255, 255, 255, 0.42);
                font-size: 12px;
            }

            /* Sağ bölüm */

            .login-section {
                position: relative;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 45px 65px;
                background-color: var(--gray-50);
            }

            .login-section::before {
                content: "";
                position: absolute;
                width: 260px;
                height: 260px;
                right: 2%;
                bottom: 4%;
                border-radius: 50%;
                background-color: rgba(197, 21, 47, 0.035);
                filter: blur(1px);
            }

            .login-container {
                position: relative;
                z-index: 2;
                width: 100%;
                max-width: 440px;
            }

            .mobile-brand {
                display: none;
                margin-bottom: 38px;
            }

            .mobile-brand .brand-name {
                color: var(--navy-900);
            }

            .login-heading {
                margin-bottom: 8px;
                color: var(--navy-950);
                font-size: 32px;
                line-height: 1.25;
                letter-spacing: -1px;
                font-weight: 750;
            }

            .login-subtitle {
                margin-bottom: 34px;
                color: var(--gray-500);
                font-size: 14px;
                line-height: 1.7;
            }

            .validation-summary {
                margin-bottom: 22px;
                padding: 13px 15px;
                border: 1px solid rgba(197, 21, 47, 0.18);
                border-left: 4px solid var(--red-600);
                border-radius: 9px;
                background-color: rgba(197, 21, 47, 0.055);
                color: var(--red-700);
                font-size: 13px;
                line-height: 1.5;
            }

            .validation-summary:empty,
            .validation-summary-valid {
                display: none;
            }

            .validation-summary ul {
                margin: 0;
                padding-left: 17px;
            }

            .form-group {
                margin-bottom: 21px;
            }

            .form-label {
                display: block;
                margin-bottom: 8px;
                color: var(--gray-700);
                font-size: 13px;
                font-weight: 650;
            }

            .input-wrapper {
                position: relative;
            }

            .input-icon {
                position: absolute;
                top: 50%;
                left: 15px;
                width: 19px;
                height: 19px;
                color: var(--gray-400);
                transform: translateY(-50%);
                pointer-events: none;
            }

            .form-control {
                width: 100%;
                height: 52px;
                padding: 0 45px;
                border: 1px solid var(--gray-200);
                border-radius: 11px;
                outline: none;
                background-color: var(--white);
                color: var(--gray-900);
                font-family: inherit;
                font-size: 14px;
                transition:
                    border-color 0.2s ease,
                    box-shadow 0.2s ease,
                    background-color 0.2s ease;
            }

            .form-control::placeholder {
                color: #a8b2c1;
            }

            .form-control:hover {
                border-color: #cbd5e1;
            }

            .form-control:focus {
                border-color: var(--navy-700);
                box-shadow: 0 0 0 4px rgba(27, 74, 120, 0.09);
            }

            .input-validation-error {
                border-color: var(--red-600);
                box-shadow: 0 0 0 3px rgba(197, 21, 47, 0.07);
            }

            .field-validation-error {
                display: block;
                margin-top: 7px;
                color: var(--red-600);
                font-size: 12px;
            }

            .password-toggle {
                position: absolute;
                top: 50%;
                right: 13px;
                width: 32px;
                height: 32px;
                display: grid;
                place-items: center;
                padding: 0;
                border: none;
                border-radius: 7px;
                background: transparent;
                color: var(--gray-400);
                cursor: pointer;
                transform: translateY(-50%);
            }

            .password-toggle:hover {
                background-color: var(--gray-100);
                color: var(--gray-700);
            }

            .password-toggle svg {
                width: 18px;
                height: 18px;
            }

            .form-options {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 15px;
                margin: 3px 0 27px;
            }

            .remember-wrapper {
                display: inline-flex;
                align-items: center;
                gap: 9px;
                color: var(--gray-700);
                font-size: 13px;
                cursor: pointer;
            }

            .remember-checkbox {
                width: 17px;
                height: 17px;
                accent-color: var(--red-600);
                cursor: pointer;
            }

            .forgot-password {
                color: var(--navy-700);
                font-size: 13px;
                font-weight: 650;
                text-decoration: none;
            }

            .forgot-password:hover {
                color: var(--red-600);
                text-decoration: underline;
            }

            .login-button {
                width: 100%;
                height: 53px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 9px;
                border: none;
                border-radius: 11px;
                background-color: var(--red-600);
                color: var(--white);
                font-family: inherit;
                font-size: 14px;
                font-weight: 700;
                letter-spacing: 0.1px;
                cursor: pointer;
                box-shadow: 0 12px 25px rgba(197, 21, 47, 0.2);
                transition:
                    background-color 0.2s ease,
                    transform 0.2s ease,
                    box-shadow 0.2s ease;
            }

            .login-button:hover {
                background-color: var(--red-700);
                box-shadow: 0 15px 30px rgba(197, 21, 47, 0.27);
                transform: translateY(-1px);
            }

            .login-button:active {
                transform: translateY(0);
            }

            .login-button svg {
                width: 18px;
                height: 18px;
            }

            .security-info {
                display: flex;
                align-items: flex-start;
                gap: 10px;
                margin-top: 23px;
                padding: 13px 14px;
                border: 1px solid var(--gray-200);
                border-radius: 10px;
                background-color: var(--white);
                color: var(--gray-500);
                font-size: 11px;
                line-height: 1.55;
            }

            .security-info svg {
                flex: 0 0 auto;
                width: 17px;
                height: 17px;
                margin-top: 1px;
                color: var(--navy-700);
            }

            .login-footer {
                margin-top: 38px;
                color: var(--gray-400);
                font-size: 11px;
                line-height: 1.6;
                text-align: center;
            }

            @@media (max-width: 1050px) {
                .login-page {
                    grid-template-columns: 0.95fr 1.05fr;
                }

                .login-showcase {
                    padding: 42px 35px;
                }

                .feature-list {
                    grid-template-columns: 1fr;
                }

                .feature-card {
                    display: grid;
                    grid-template-columns: 36px 1fr;
                    column-gap: 10px;
                }

                .feature-icon {
                    grid-row: span 2;
                    margin-bottom: 0;
                }

                .login-section {
                    padding: 45px;
                }
            }

            @@media (max-width: 820px) {
                .login-page {
                    display: block;
                }

                .login-showcase {
                    display: none;
                }

                .login-section {
                    min-height: 100vh;
                    padding: 40px 24px;
                }

                .mobile-brand {
                    display: flex;
                }
            }

            @@media (max-width: 480px) {
                .login-section {
                    align-items: flex-start;
                    padding: 28px 20px;
                }

                .mobile-brand {
                    margin-bottom: 43px;
                }

                .login-heading {
                    font-size: 28px;
                }

                .form-options {
                    align-items: flex-start;
                    flex-direction: column;
                    gap: 14px;
                }
            }
    </style>
</head>

<body>

    <main class="login-page">

        <section class="login-showcase">

            <header class="showcase-header">
                <div class="brand">

                    <div class="brand-symbol">
                        <svg viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2">
                            <path d="M3 21h18" />
                            <path d="M5 21V10" />
                            <path d="M19 21V10" />
                            <path d="M4 10h16" />
                            <path d="M12 3 3 8h18L12 3Z" />
                            <path d="M9 14v3" />
                            <path d="M15 14v3" />
                        </svg>
                    </div>

                    <div>
                        <div class="brand-name">BankCRM</div>
                        <div class="brand-description">Kurumsal Bankacılık Platformu</div>
                    </div>

                </div>
            </header>

            <div class="showcase-content">

                <div class="showcase-badge">
                    <span class="badge-dot"></span>
                    Güvenli personel erişimi
                </div>

                <h1 class="showcase-title">
                    Müşteri ilişkilerini daha
                    <span>etkili</span> yönetin.
                </h1>

                <p class="showcase-text">
                    Müşteri süreçlerini, banka ürünlerini, başvuruları ve personel
                    aktivitelerini güvenli ve merkezi bir platform üzerinden yönetin.
                </p>

                <div class="feature-list">

                    <article class="feature-card">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                        </div>

                        <strong class="feature-title">Müşteri Yönetimi</strong>

                        <span class="feature-description">
                            Müşteri bilgilerine ve süreçlerine tek noktadan erişin.
                        </span>
                    </article>

                    <article class="feature-card">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <path d="M3 3v18h18" />
                                <path d="m7 16 4-5 4 3 5-7" />
                            </svg>
                        </div>

                        <strong class="feature-title">Finansal Analiz</strong>

                        <span class="feature-description">
                            Başvuruları ve ürün dağılımlarını anlık takip edin.
                        </span>
                    </article>

                    <article class="feature-card">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                                <path d="m9 12 2 2 4-4" />
                            </svg>
                        </div>

                        <strong class="feature-title">Güvenli İşlemler</strong>

                        <span class="feature-description">
                            Rol bazlı erişim ve güvenli oturum yönetimi.
                        </span>
                    </article>

                </div>

            </div>

            <footer class="showcase-footer">
                Yalnızca yetkili banka personelinin kullanımına açıktır.
            </footer>

        </section>

        <section class="login-section">

            <div class="login-container">

                <div class="mobile-brand brand">

                    <div class="brand-symbol">
                        <svg viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2">
                            <path d="M3 21h18" />
                            <path d="M5 21V10" />
                            <path d="M19 21V10" />
                            <path d="M4 10h16" />
                            <path d="M12 3 3 8h18L12 3Z" />
                        </svg>
                    </div>

                    <div>
                        <div class="brand-name">BankCRM</div>
                        <div class="brand-description">Personel Portalı</div>
                    </div>

                </div>

                <h2 class="login-heading">Tekrar hoş geldiniz</h2>

                <p class="login-subtitle">
                    BankCRM personel hesabınıza erişmek için giriş bilgilerinizi yazın.
                </p>

                <form asp-controller="Auth"
                      asp-action="Login"
                      method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="validation-summary">
                    </div>

                    <div class="form-group">

                        <label asp-for="UserNameOrEmail"
                               class="form-label">
                            Kullanıcı adı veya e-posta
                        </label>

                        <div class="input-wrapper">

                            <svg class="input-icon"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <path d="M20 21a8 8 0 0 0-16 0" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>

                            <input asp-for="UserNameOrEmail"
                                   class="form-control"
                                   placeholder="kullaniciadi veya personel@bankcrm.com"
                                   autocomplete="username" />

                        </div>

                        <span asp-validation-for="UserNameOrEmail"
                              class="field-validation-error">
                        </span>

                    </div>

                    <div class="form-group">

                        <label asp-for="Password"
                               class="form-label">
                            Şifre
                        </label>

                        <div class="input-wrapper">

                            <svg class="input-icon"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <rect width="18"
                                      height="11"
                                      x="3"
                                      y="11"
                                      rx="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>

                            <input asp-for="Password"
                                   class="form-control"
                                   id="passwordInput"
                                   placeholder="Şifrenizi yazın"
                                   autocomplete="current-password" />

                            <button type="button"
                                    class="password-toggle"
                                    id="passwordToggle"
                                    aria-label="Şifreyi göster veya gizle">

                                <svg id="eyeIcon"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2">
                                    <path d="M2.06 12.35a1 1 0 0 1 0-.7C3.73 7.6 7.65 5 12 5c4.35 0 8.27 2.6 9.94 6.65a1 1 0 0 1 0 .7C20.27 16.4 16.35 19 12 19c-4.35 0-8.27-2.6-9.94-6.65Z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>

                            </button>

                        </div>

                        <span asp-validation-for="Password"
                              class="field-validation-error">
                        </span>

                    </div>

                    <div class="form-options">

                        <label class="remember-wrapper">
                            <input asp-for="RememberMe"
                                   class="remember-checkbox" />

                            <span>Beni hatırla</span>
                        </label>

                        <a href="javascript:void(0)"
                               class="forgot-password">
                            Şifremi unuttum
                        </a>

                    </div>

                    <button type="submit"
                            class="login-button">

                        <span>Giriş Yap</span>

                        <svg viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2">
                            <path d="M5 12h14" />
                            <path d="m13 6 6 6-6 6" />
                        </svg>

                    </button>

                </form>

                <div class="security-info">

                    <svg viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                        <path d="m9 12 2 2 4-4" />
                    </svg>

                    <span>
                        Oturumunuz güvenli bir bağlantı üzerinden korunmaktadır.
                        Giriş bilgilerinizi başka kişilerle paylaşmayın.
                    </span>

                </div>

                <footer class="login-footer">
                    © @DateTime.Now.Year BankCRM — Kurum içi banka personel portalı
                </footer>

            </div>

        </section>

    </main>

    <script>
            const passwordInput = document.getElementById("passwordInput");
            const passwordToggle = document.getElementById("passwordToggle");
            const eyeIcon = document.getElementById("eyeIcon");

            passwordToggle.addEventListener("click", function () {
                const passwordIsHidden = passwordInput.type === "password";

                passwordInput.type = passwordIsHidden ? "text" : "password";

                if (passwordIsHidden) {
                    eyeIcon.innerHTML = `
                        <path d="m2 2 20 20"></path>
                        <path d="M6.71 6.71C4.93 7.89 3.5 9.6 2.66 11.65a1 1 0 0 0 0 .7C4.33 16.4 8.25 19 12.6 19c1.55 0 3.03-.33 4.36-.92"></path>
                        <path d="M10.73 5.08A9.77 9.77 0 0 1 12.6 5c4.35 0 8.27 2.6 9.94 6.65a1 1 0 0 1 0 .7 10.1 10.1 0 0 1-1.38 2.35"></path>
                        <path d="M14.72 14.72a3 3 0 0 1-4.24-4.24"></path>`;
                }
                else {
                    eyeIcon.innerHTML = `
                        <path d="M2.06 12.35a1 1 0 0 1 0-.7C3.73 7.6 7.65 5 12 5c4.35 0 8.27 2.6 9.94 6.65a1 1 0 0 1 0 .7C20.27 16.4 16.35 19 12 19c-4.35 0-8.27-2.6-9.94-6.65Z"></path>
                        <circle cx="12" cy="12" r="3"></circle>`;
                }
            });
    </script>

</body>
</html>